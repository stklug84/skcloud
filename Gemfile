source 'https://rubygems.org'

# Explicitly add Jekyll so the command is found
gem 'jekyll'

# Add GitHub Pages support
gem 'github-pages'

# Required for Ruby 3.0+ (which GitHub Actions uses)
gem 'webrick'

# Ruby 3.4+ removed several stdlib libs from default gems; jekyll 3.9 still requires them.
gem 'csv'
gem 'bigdecimal'
gem 'logger'
gem 'base64'
